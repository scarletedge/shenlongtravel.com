        <a class="chat-link link-only" href="https://u.wechat.com/IFqnIQXgeYjfpA9Fxz9yUGs?s=2" target="_blank" rel="noopener">点击开始对话</a>
      </div>
    </div>
    <div class="ch">
      <img class="qr qr-only" src="../images/qr-line.png" alt="LINE 二维码" width="64" height="64" loading="lazy">
      <div>
        <span class="ch-name">LINE</span><br>
        <span class="ch-hint qr-only">扫码加好友</span>
        <a class="chat-link link-only" href="https://line.me/ti/p/tg6LUFsHGD" target="_blank" rel="noopener">点击开始对话</a>
      </div>
    </div>
    <div class="ch">
      <img class="qr qr-only" src="../images/qr-whatsapp.png" alt="WhatsApp 二维码" width="64" height="64" loading="lazy">
      <div>
        <span class="ch-name">WhatsApp</span><br>
        <span class="ch-hint qr-only">扫码开始对话</span>
        <a class="chat-link link-only" href="https://wa.me/qr/O264YVQPDFH4G1" target="_blank" rel="noopener">点击开始对话</a>
      </div>
    </div>
    <div class="ch">
      <div class="ch-icon-fallback">Z</div>
      <div>
        <span class="ch-name">Zalo</span><br>
        <span class="ch-hint">越南在地联系首选</span>
        <a class="chat-link" href="https://zalo.me/84975898625" target="_blank" rel="noopener">点击开始对话</a>
      </div>
    </div>
  </div>
  <button class="widget-toggle" aria-label="打开咨询窗口" aria-expanded="false">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
  </button>
</div>

<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.0/firebase-firestore-compat.js"></script>
<script src="../js/firebase-config.js"></script>
<script src="../js/widget.js"></script>
<script>
(function () {
  var CNY_TO_USD = 1 / 6.7716;
  var CNY_TO_VND = 3868;

  var PRICES = [
    ['arrival','15','单次','3–4个工作日',25],
    ['arrival','15','单次','1个工作日',40],
    ['arrival','15','单次','当天出签（11:00前送件）',120],
    ['arrival','30','单次','3–4个工作日',35],
    ['arrival','30','单次','1个工作日',50],
    ['arrival','30','单次','当天出签（11:00前送件）',140],
    ['arrival','30','多次','5个工作日',null],
    ['arrival','30','多次','3–4个工作日',null],
    ['arrival','30','多次','1个工作日',120],
    ['embassy','15','单次','3–4个工作日（4工后生效）',240],
    ['embassy','15','单次','1个工作日（1工后生效）',280],
    ['embassy','15','单次','当天出签',null],
    ['embassy','15','单次','4小时加急',null],
    ['embassy','30','单次','3–4个工作日（4工后生效）',260],
    ['embassy','30','单次','1个工作日（1工后生效）',300],
    ['embassy','30','单次','当天出签',null],
    ['embassy','30','单次','4小时加急',null],
    ['embassy','30','多次','1–2个工作日',550],
    ['evisa','90','单次','4个工作日',250],
    ['evisa','90','多次','4个工作日',450],
    ['evisa','90','单次','3个工作日',240],
    ['evisa','90','多次','3个工作日',430],
    ['evisa','90','单次','2个工作日（截止15:30）',300],
    ['evisa','90','多次','2个工作日（截止15:30）',500],
    ['evisa','90','单次','1个工作日（截止15:30）',350],
    ['evisa','90','多次','1个工作日（截止15:30）',550],
    ['evisa','90','单次','特急件・当天出签（截止9:30）',450],
    ['evisa','90','多次','特急件・当天出签（截止9:30）',650],
    ['evisa','90','单次','4小时加急（截止14:30）',550],
    ['evisa','90','多次','4小时加急（截止14:30）',750],
  ];

  var catBtns = document.querySelectorAll('#calc-category .calc-pill');
  var durationSel = document.getElementById('calc-duration');
  var speedSel = document.getElementById('calc-speed');
  var resultBox = document.getElementById('calc-result');
  if (!catBtns.length) return;

  var state = { category: null, duration: null, speed: null };

  function fmtPrice(cny) {
    if (cny === null || cny === undefined) {
      return '<span class="price-ask">价格详询</span><div class="hint">此选项需人工报价，请私信客服洽询。</div>';
    }
    var usd = (cny * CNY_TO_USD).toFixed(2);
    var vnd = Math.round(cny * CNY_TO_VND / 1000) * 1000;
    return '<div class="price-usd">US$' + usd + '</div>' +
      '<div class="price-vnd">≈ ' + vnd.toLocaleString('en-US') + '₫</div>' +
      '<div class="hint">屏幕截图这个结果，私信右下角咨询按钮给客服即可开始办理。</div>';
  }

  function updateDurationOptions() {
    var rows = PRICES.filter(function (r) { return r[0] === state.category; });
    var seen = {}, opts = [];
    rows.forEach(function (r) {
      var key = r[1] + '天・' + r[2];
      if (!seen[key]) { seen[key] = true; opts.push({ key: key, stay: r[1], entry: r[2] }); }
    });
    durationSel.innerHTML = '<option value="">请选择</option>' +
      opts.map(function (o) { return '<option value="' + o.stay + '|' + o.entry + '">' + o.key + '</option>'; }).join('');
    durationSel.disabled = false;
    speedSel.innerHTML = '<option>请先选择天数与次数</option>';
    speedSel.disabled = true;
    resultBox.innerHTML = '<span style="color:var(--muted);font-size:14px">选择以上选项后，这里会显示报价</span>';
  }

  function updateSpeedOptions() {
    var rows = PRICES.filter(function (r) {
      return r[0] === state.category && (r[1] + '|' + r[2]) === state.duration;
    });
    speedSel.innerHTML = '<option value="">请选择</option>' +
      rows.map(function (r, i) { return '<option value="' + i + '">' + r[3] + '</option>'; }).join('');
    speedSel.disabled = false;
    speedSel.dataset.rows = JSON.stringify(rows);
    resultBox.innerHTML = '<span style="color:var(--muted);font-size:14px">选择以上选项后，这里会显示报价</span>';
  }

  function initCalculator() {
    catBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        catBtns.forEach(function (b) { b.classList.remove('active'); });
        btn.classList.add('active');
        state.category = btn.dataset.value;
        updateDurationOptions();
      });
    });

    durationSel.addEventListener('change', function () {
      state.duration = durationSel.value;
      if (!state.duration) return;
      updateSpeedOptions();
    });

    speedSel.addEventListener('change', function () {
      var rows = JSON.parse(speedSel.dataset.rows || '[]');
      var row = rows[Number(speedSel.value)];
      if (!row) return;
      resultBox.innerHTML = fmtPrice(row[4]);
    });
  }

  if (typeof FIREBASE_READY !== 'undefined' && FIREBASE_READY) {
    Promise.all([
      db.collection('siteSettings').doc('exchangeRates').get(),
      db.collection('visaPrices').orderBy('order').get()
    ]).then(function (results) {
      var ratesDoc = results[0], pricesSnap = results[1];
      if (ratesDoc.exists) {
        var r = ratesDoc.data();
        if (r.cnyToUsd) CNY_TO_USD = r.cnyToUsd;
        if (r.cnyToVnd) CNY_TO_VND = r.cnyToVnd;
      }
      if (!pricesSnap.empty) {
        var fresh = [];
        pricesSnap.forEach(function (doc) {
          var d = doc.data();
          fresh.push([d.category, d.stay, d.entrySimp, d.speedSimp, d.priceCNY]);
        });
        PRICES = fresh;
      }
      initCalculator();
    }).catch(function () { initCalculator(); });
  } else {
    initCalculator();
  }
})();
</script>
</body>
</html>
