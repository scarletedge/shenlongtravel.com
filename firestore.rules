/* =========================================================
   Firestore 安全規則
   把這整份內容貼到 Firebase Console →
   Firestore Database → 規則（Rules）分頁，取代原本的內容，
   然後按「發布」。

   邏輯：
   - 所有人都可以「讀取」資料（公開網站要顯示價格、團隊介紹）
   - 只有「已登入」的帳號（也就是妳幫員工建的後台帳號）
     才可以「寫入／修改／刪除」資料
   ========================================================= */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /visaPrices/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /teamMembers/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /guides/{docId} {
      // 導遊自己填表單報名，任何人都可以「新增」一筆申請
      allow create: if true;
      // 但名單內容（含聯絡方式）只有登入的員工可以查看／審核／修改／刪除
      allow read, update, delete: if request.auth != null;
    }

    match /guideRequests/{docId} {
      // 客戶送出配對需求，任何人都可以「新增」一筆需求
      allow create: if true;
      // 需求內容（含客戶聯絡方式）只有登入的員工可以查看／處理／刪除
      allow read, update, delete: if request.auth != null;
    }

    match /fleetRoutesPublic/{docId} {
      // 售價資料：公開網站要顯示給客戶看
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /fleetRoutesCost/{docId} {
      // 成本資料：絕對不公開，只有登入員工能讀取（給後台派車工具用）
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /fastTrackServices/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /fastTrackRequests/{docId} {
      // 客戶送出快速通關預約需求（不含護照/簽證/航班等敏感資料，那些改私訊客服提供）
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /itineraryRequests/{docId} {
      // 客戶送出定制行程需求（不含護照等敏感資料）
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 之後新增其他資料表（例如包車、部落格文章），
    // 照上面的格式複製一段貼在這裡即可。
  }
}
