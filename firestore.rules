          <tr><td>90天</td><td>单次</td><td>1个工作日（截止15:30）</td><td>US$51.69<span class="vnd-ref">≈ 1,354,000₫</span></td></tr>
          <tr><td>90天</td><td>多次</td><td>1个工作日（截止15:30）</td><td>US$81.22<span class="vnd-ref">≈ 2,127,000₫</span></td></tr>
